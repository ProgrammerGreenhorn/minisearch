{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug minisearch: src",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/minisearch",
      "args": [
        "${workspaceFolder}/src"
      ],
      "stopOnEntry": false,
      "cwd": "${workspaceFolder}",
      "env": {},
      "terminal": "integrated",
      "preLaunchTask": "cmake: build debug"
    },
    {
      "name": "Debug minisearch: interactive",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/minisearch",
      "args": [],
      "stopOnEntry": false,
      "cwd": "${workspaceFolder}",
      "env": {},
      "terminal": "integrated",
      "preLaunchTask": "cmake: build debug"
    }
  ]
}
